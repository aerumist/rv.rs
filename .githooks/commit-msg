#!/usr/bin/env bash
# Enforce conventional commit format.
# Allowed: feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert|release
set -euo pipefail

msg=$(head -1 "$1")

# Allow merge commits
[[ "$msg" =~ ^Merge ]] && exit 0

pattern='^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert|release)(\(.+\))?(!)?: .+'

if ! [[ "$msg" =~ $pattern ]]; then
  echo "error: commit message does not follow Conventional Commits" >&2
  echo "" >&2
  echo "  Expected: <type>[optional scope]: <description>" >&2
  echo "  Types: feat fix docs style refactor perf test build ci chore revert release" >&2
  echo "" >&2
  echo "  Got: $msg" >&2
  exit 1
fi
