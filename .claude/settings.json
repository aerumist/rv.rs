{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/scripts/post-edit-hook.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/scripts/post-commit-changelog.sh",
            "if": "Bash(git commit *)",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
